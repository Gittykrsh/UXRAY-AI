html {
    scroll-behavior: smooth;
}

section {
    scroll-margin-top: 100px;
    position: relative;
    z-index: 1;
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #020617; /* Deep slate background */
    color: #f8fafc;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
}

/* ENHANCED BACKGROUND EFFECTS (ANTIGRAVITY STYLE) */
body::before {
    content: "";
    position: fixed;
    width: 800px;
    height: 800px;
    top: -200px;
    left: -200px;
    background: radial-gradient(circle, rgba(255,255,255,0.03), transparent 60%);
    border-radius: 50%;
    filter: blur(120px);
    animation: floatGlow 25s ease-in-out infinite alternate;
    z-index: -2;
    pointer-events: none;
}

body::after {
    content: "";
    position: fixed;
    inset: 0;
    background:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.5;
    z-index: -2;
    pointer-events: none;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
    -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);
}

/* TYPOGRAPHY REFINEMENTS */
h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.03em;
    font-weight: 600;
}

/* GEOMETRIC FLOATING SHAPES */
.geometric-shape {
    display: none;
}

.geometric-shape:nth-child(1) {
    top: 10%;
    left: 5%;
    width: 120px;
    height: 120px;
    background: linear-gradient(45deg, rgba(56,189,248,0.3), rgba(99,102,241,0.2));
    clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    animation-delay: 0s;
}

.geometric-shape:nth-child(2) {
    top: 70%;
    right: 10%;
    width: 80px;
    height: 80px;
    background: linear-gradient(45deg, rgba(99,102,241,0.25), rgba(56,189,248,0.15));
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    animation-delay: 5s;
}

.geometric-shape:nth-child(3) {
    bottom: 20%;
    left: 20%;
    width: 60px;
    height: 60px;
    background: linear-gradient(45deg, rgba(56,189,248,0.2), rgba(99,102,241,0.3));
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    animation-delay: 10s;
}

/* ANIMATIONS */
@keyframes floatGlow {
    0%, 100% {
        transform: translate(0, 0) scale(1) rotate(0deg);
        opacity: 0.8;
    }
    25% {
        transform: translate(30px, -20px) scale(1.05) rotate(90deg);
        opacity: 1;
    }
    50% {
        transform: translate(-20px, 30px) scale(1.1) rotate(180deg);
        opacity: 0.9;
    }
    75% {
        transform: translate(40px, 40px) scale(1.08) rotate(270deg);
        opacity: 0.85;
    }
}

@keyframes particleFloat {
    0%, 100% {
        transform: translate(0, 0) scale(1);
        opacity: 0.3;
    }
    50% {
        transform: translate(100px, -50px) scale(1.2);
        opacity: 0.8;
    }
}

@keyframes geometricFloat {
    0% {
        transform: translate(0, 0) rotate(0deg) scale(1);
        opacity: 0.05;
    }
    25% {
        transform: translate(200px, -100px) rotate(90deg) scale(1.1);
        opacity: 0.08;
    }
    50% {
        transform: translate(-150px, 150px) rotate(180deg) scale(0.9);
        opacity: 0.06;
    }
    75% {
        transform: translate(300px, 200px) rotate(270deg) scale(1.05);
        opacity: 0.07;
    }
    100% {
        transform: translate(0, 0) rotate(360deg) scale(1);
        opacity: 0.05;
    }
}

/* PAGE TRANSITIONS */
.page-transition {
    opacity: 1;
    transform: none;
    will-change: opacity, transform;
}

@keyframes pageFadeIn {
    0% {
        opacity: 0;
        transform: translateY(20px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

.fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
}

/* SMOOTH NAVIGATION TRANSITIONS */
nav a {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

nav a:hover {
    transform: translateY(-2px);
    text-shadow: 0 0 20px rgba(56, 189, 248, 0.5);
}

/* Legacy hover effects removed for production-readiness */


/* SUBTLE SCROLL ANIMATIONS */
@keyframes fadeInUp {
    0% {
        opacity: 0;
        transform: translateY(30px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

.fade-in-up {
    animation: fadeInUp 0.8s ease-out;
}

/* LOADING SPINNER ENHANCEMENT */
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loading-spinner {
    border: 3px solid rgba(56, 189, 248, 0.1);
    border-top: 3px solid #38bdf8;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin: 20px auto;
}

/* CONTAINER */
.container {
    width: 85%;
    margin: auto;
}

/* NAVBAR */
header {
    position: fixed;
    width: 100%;
    top: 0;
    backdrop-filter: blur(12px);
    background: rgba(2,6,23,0.7);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    z-index: 100;
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
}

.nav-left h2 {
    color: white;
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 18px;
}

.nav-right a {
    margin: 0 12px;
    text-decoration: none;
    color: #94a3b8;
    transition: 0.3s;
}

.nav-right a:hover {
    color: #38bdf8;
}

.nav-right button {
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    background: linear-gradient(to right, #38bdf8, #818cf8);
    color: white;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
}

.nav-right button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(56,189,248,0.3);
}

/* HERO (FULL SCREEN 🔥) */
#hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 40px;
    padding-bottom: 40px;
    text-align: center;
}

#hero-background {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at top, rgba(56,189,248,0.1), transparent 55%);
    pointer-events: none;
}

.hero-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 13px;
    font-weight: 500;
    color: #a1a1aa;
    margin-bottom: 24px;
    transition: 0.3s ease;
    cursor: pointer;
}

.hero-badge:hover {
    background: rgba(255,255,255,0.1);
    color: white;
}

.hero-content h1 {
    font-size: 64px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.04em;
    background: linear-gradient(180deg, #ffffff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.hero-content p {
    margin-top: 18px;
    font-size: 18px;
    color: #94a3b8;
    max-width: 620px;
    margin-left: auto;
    margin-right: auto;
}

/* HERO BUTTONS */
.hero-buttons {
    margin-top: 20px;
    display: inline-flex;
    justify-content: center;
    gap: 14px;
}

.hero-buttons button {
    padding: 12px 22px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: 0.3s;
}

.hero-buttons a:first-child button {
    background: #ffffff;
    color: #000000;
    font-weight: 500;
}

.hero-buttons button:last-child {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    font-weight: 500;
}

.hero-buttons button:hover {
    transform: translateY(-1px);
}

/* SECTIONS SPACING 🔥 */
#features,
#how-it-works,
#pricing,
#cta {
    padding: 90px 0;
}

/* SECTION HEADERS */
.section-header {
    text-align: center;
    margin-bottom: 50px;
}

.section-header h1 {
    font-size: 54px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #818cf8;
}

.section-header h2 {
    font-size: 38px;
}

/* FEATURES GRID */
.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
}

/* GLASS CARD (GEN-Z AESTHETIC & LARGER SHAPE) */
.feature-card,
.step-card {
    background: #0f172a;
    padding: 36px 32px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.05);
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

/* Subtle inner glow for depth */
.feature-card::before,
.step-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(800px circle at 0% 0%, rgba(129, 140, 248, 0.08), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
}

/* HOVER (Smooth Scale + Subtle Neon Glow) */
.feature-card:hover,
.step-card:hover {
    transform: translateY(-4px) scale(1.01);
    border: 1px solid rgba(129, 140, 248, 0.3);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px rgba(129, 140, 248, 0.1);
}

.feature-card:hover::before,
.step-card:hover::before {
    opacity: 1;
}

/* STEPS */
.steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
}

/* PRICING */
.pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
}

/* BASE PRICE CARD (ALL SAME) */
.price-card {
    background: #0f172a;
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--border);
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

/* SUBTLE INNER GLOW (DEPTH EFFECT 🔥) */
.price-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
        circle at top,
        rgba(255,255,255,0.02),
        transparent 70%
    );
    opacity: 0.6;
    pointer-events: none;
}

/* HIGHLIGHTED PLAN */
.price-card.highlight {
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.3);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 24px 48px -12px rgba(0,0,0,0.8);
    transform: translateY(-2px);
}

.price-card.highlight::after {
    content: "Most Popular";
    position: absolute;
    top: 20px;
    right: 20px;
    background: #ffffff;
    color: #000000;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
}

/* HOVER EFFECT (ALL SAME 🔥) */
.price-card:hover {
    transform: translateY(-4px);
    border: 1px solid rgba(255,255,255,0.2);
}

/* TEXT IMPROVEMENT */
.price-card h3 {
    font-size: 20px;
    margin-bottom: 10px;
    color: #cbd5f5;
}

.price-card h1 {
    font-size: 44px;
    margin: 15px 0;
    font-weight: 600;
}

.price-card span {
    font-size: 16px;
    color: #94a3b8;
}

/* FEATURES TEXT */
.price-card p {
    color: #94a3b8;
    margin: 6px 0;
}

/* BUTTON */
.price-card button {
    margin-top: 24px;
    width: 100%;
    padding: 12px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.1);
    background: #020617;
    color: white;
    font-weight: 500;
    cursor: pointer;
    transition: 0.2s ease;
}

.price-card.highlight button {
    background: #ffffff;
    color: #000000;
    border: none;
}

.price-card button:hover {
    transform: translateY(-1px);
    background: rgba(255,255,255,0.1);
}

.price-card.highlight button:hover {
    background: #e5e5e5;
}

/* CTA */
#cta {
    text-align: center;
}

.cta-content h2 {
    font-size: 42px;
}

.cta-content p {
    margin: 20px 0;
    color: #94a3b8;
}

.cta-content button {
    padding: 14px 24px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(135deg, #38bdf8, #6366f1);
    color: white;
    cursor: pointer;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 40px 0;
    color: #64748b;
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .hero-content h1 {
        font-size: 36px;
    }

    .section-header h2 {
        font-size: 28px;
    }
}

/* ================= AUTH PAGE (LOGIN / SIGNUP) ================= */

/* CENTER ONLY AUTH PAGE */
body:has(input[type="password"]) {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

/* FORM CONTAINER AUTO TARGET */
body:has(input[type="password"]) > * {
    width: 100%;
    max-width: 400px;
}

/* GLASS CARD */
body:has(input[type="password"]) form,
body:has(input[type="password"]) > div {
    background: var(--bg-card);
    padding: 40px;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

/* HEADINGS */
body:has(input[type="password"]) h2,
body:has(input[type="password"]) h1 {
    font-size: 24px;
    margin-bottom: 8px;
    color: white;
    font-weight: 700;
}

body:has(input[type="password"]) p {
    color: #94a3b8;
    margin-bottom: 24px;
    font-size: 14px;
}

/* INPUTS */
body:has(input[type="password"]) .input-group label {
    display: block;
    font-size: 13px;
    color: #e2e8f0;
    margin-bottom: 6px;
    font-weight: 500;
}

body:has(input[type="password"]) input {
    width: 100%;
    padding: 12px 14px;
    margin: 0 0 16px 0;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-input);
    color: white;
    outline: none;
    transition: 0.2s ease;
    font-family: inherit;
    font-size: 14px;
}

body:has(input[type="password"]) input::placeholder {
    color: #475569;
}

body:has(input[type="password"]) input:focus {
    border: 1px solid #3b82f6;
    box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
}

/* BUTTON */
body:has(input[type="password"]) button {
    width: 100%;
    padding: 12px;
    border-radius: 6px;
    border: none;
    background: #ffffff;
    color: #000000;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 8px;
}

body:has(input[type="password"]) button:hover {
    background: #e5e5e5;
    transform: scale(1.02);
}

/* LINK TEXT */
body:has(input[type="password"]) a {
    color: #38bdf8;
    text-decoration: none;
}

body:has(input[type="password"]) a:hover {
    text-decoration: underline;
}

/* BOTTOM TEXT */
body:has(input[type="password"]) p:last-child {
    text-align: center;
    margin-top: 15px;
}

/* ================= DASHBOARD HERO (INITIAL VIEW) ================= */

/* ================= DASHBOARD ONLY CLEAN CSS ================= */

/* ========================= */
/*   CLEAN DASHBOARD UI CSS  */
/* ========================= */

/* ========================= */
/*   FINAL DASHBOARD UI CSS  */
/* ========================= */

/* ROOT THEME */
:root {
    --bg-main: #020617;
    --bg-card: #1e293b;
    --bg-input: #0f172a;

    --text-main: #f8fafc;
    --text-secondary: #94a3b8;

    --primary: #ffffff;
    --secondary: #334155;
    
    --accent: #2563eb; /* True Blue */

    --border: rgba(255,255,255,0.08);
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Poppins', sans-serif;
    background: var(--bg-main);
    color: var(--text-main);
}

/* ================= NAVBAR ================= */

.dashboard-nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;

    backdrop-filter: blur(14px);
    background: rgba(11,18,32,0.7);

    border-bottom: 1px solid var(--border);
    padding: 14px 0;
}

.dashboard-nav-inner {
    width: 90%;
    max-width: 1200px;
    margin: auto;

    display: flex;
    justify-content: space-between;
    align-items: center;
}

.dashboard-nav h2 {
    font-size: 22px;
}

/* RIGHT SIDE */
.nav-actions {
    display: flex;
    align-items: center;
    gap: 18px; /* FIXED spacing */
}

/* POINTS */
.points-box {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #1e293b;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
}

/* LANGUAGE */
#language-select {
    padding: 8px 16px;
    border-radius: 8px;
    background: #1e293b;
    color: white;
    border: 1px solid rgba(255,255,255,0.05);
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
}

/* LOGOUT */
#logout-btn {
    padding: 8px 16px;
    border-radius: 8px;
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.05);
    color: #ef4444;
    font-weight: 500;
    font-size: 13px;
    cursor: pointer;
}

#logout-btn:hover {
    background: #ef4444;
    color: white;
}

/* UPGRADE PLAN BUTTON */
.upgrade-btn {
    background: #0070f3;
    color: white;
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 6px;
    font-weight: 500;
    font-size: 13px;
    transition: 0.2s ease;
    white-space: nowrap;
    border: 1px solid rgba(255,255,255,0.1);
}

.upgrade-btn:hover {
    background: #0051b3;
    transform: scale(1.02);
}

/* ================= MAIN CENTER ================= */

.dashboard-main {
    width: 100%;
    max-width: 1200px;
    margin: 100px auto 30px;

    display: flex;
    flex-direction: column; /* FORCE vertical */
    align-items: center;

    gap: 30px;
}

/* ================= ANALYZER CARD ================= */

.analyze-card {
    width: 100%;
    max-width: 700px;
    margin: 40px auto 0;
    padding: 32px;
    border-radius: 16px;
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: 0.3s;
}

.analyze-card:hover {
    box-shadow: 0 30px 80px rgba(99,102,241,0.25);
}

/* TEXT */
.analyze-card h2 {
    font-size: 28px;
}

.analyze-card p {
    font-size: 16px;
    color: var(--text-secondary);
}

/* INPUT */
.analyze-card input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
    background: #0f172a;
    color: white;
    font-size: 14px;
    outline: none;
    transition: 0.3s;
    font-family: inherit;
}

.analyze-card input::placeholder {
    color: #64748b;
}

/* ================= DROPDOWN ================= */

.custom-dropdown {
    position: relative;
    width: 100%;
}

.dropdown-selected {
    padding: 14px 16px;
    border-radius: 8px;
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.05);
    font-size: 14px;
    color: #e2e8f0;
}

.dropdown-options {
    position: absolute;
    top: 110%;
    left: 0;
    width: 100%;

    background: #0f172a;
    border-radius: 14px;

    border: 1px solid var(--border);
    overflow: hidden;

    display: none;
    z-index: 9999;
}

.dropdown-options div {
    padding: 14px;
}

.dropdown-options div:hover {
    background: rgba(99,102,241,0.3);
}

/* ================= BUTTON ================= */

#analyze-btn {
    margin-top: 8px;
    padding: 14px;
    border-radius: 6px;
    border: none;
    background: #ffffff;
    color: #000000;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: 0.2s ease;
}

#analyze-btn:hover {
    transform: translateY(-1px);
    background: #e5e5e5;
}

/* ================= RESULTS ================= */

.results-section {
    width: 100%;
    max-width: 1100px;

    display: flex;
    flex-direction: column; /* STACK EVERYTHING */

    gap: 30px;
    margin-top: 30px;
}

/* SCORE GRID */
.score-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 18px;
}

/* GRAPH FULL WIDTH */
.chart-section {
    width: 100%;
}

/* ANALYSIS GRID FIX */
.analysis-grid {
    width: 100%;

    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-top: 16px;
}

/* REMOVE SIDE SHIFT ISSUE */
.results-section,
.analysis-grid,
.chart-section,
.score-grid {
    float: none !important;
}

.score-card {
    padding: 24px;
    border-radius: 12px;
    background: #0f172a;
    border: 1px solid var(--border);
    text-align: center;
    transition: 0.3s;
}

.score-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.score-card p {
    font-size: 32px;
    font-weight: 700;
    color: var(--text-main);
}

/* ================= LOADER ================= */

.ai-loader {
    display: none;
    margin-top: 10px;

    font-weight: 600;
    color: #6366f1;

    animation: pulse 1.2s infinite;
}

@keyframes pulse {
    0% {opacity: 0.4;}
    50% {opacity: 1;}
    100% {opacity: 0.4;}
}

/* ================= RESULTS WRAPPER ================= */
.results-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-top: 30px;
}

/* ================= SCORE CARDS ================= */
.score-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
    width: 100%;
}

.score-card {
    padding: 26px 18px;
    border-radius: 12px;
    background: #0f172a;
    border: 1px solid var(--border);
    text-align: center;
    transition: 0.3s;
}

.score-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}

.score-card h3 {
    font-size: 14px;
    margin-bottom: 10px;
    color: var(--text-main);
    font-weight: 600;
}

.score-card p {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-main);
}

/* ================= CHART ================= */
.chart-section {
    width: 100%;
    padding: 40px;
    margin-top: 20px;
    margin-bottom: 30px;
    border-radius: 20px;

    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
}

.chart-section canvas {
    margin-top: 25px;
}

/* ================= REPORTS + SUGGESTIONS ================= */
.analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-top: 16px;
}

/* CARD STYLE */
.analysis-card {
    padding: 25px;
    border-radius: 18px;

    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
}

/* ================= SCROLLABLE REPORT BOX ================= */
.reports-box {
    max-height: 300px;
    overflow-y: auto;
    padding-right: 10px;
}

/* scrollbar styling */
.reports-box::-webkit-scrollbar {
    width: 6px;
}

.reports-box::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 10px;
}

.reports-card {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 40px;
    border: 1px solid var(--border);
    margin-top: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
}

.reports-card h2 {
    margin-bottom: 20px;
}

.reports-list {
    max-height: 250px;
    overflow-y: auto;
    margin-top: 20px;
    padding-right: 12px;
}

.reports-list li {
    margin-bottom: 14px;
    line-height: 1.7;
}

.reports-list::-webkit-scrollbar {
    width: 6px;
}

.reports-list::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 10px;
}

/* ================= BUTTONS ================= */
.result-actions {
    display: flex;
    gap: 20px;
    margin-top: 25px;
}

.result-actions button {
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.2);
    font-weight: 500;
    font-size: 13px;
    background: linear-gradient(180deg, #d1d5db 0%, #6b7280 100%);
    color: #ffffff;
    cursor: pointer;
    transition: 0.2s ease;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 2px 4px rgba(0,0,0,0.5);
}

.result-actions button:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
}

/* ================= LIVE EDITOR ================= */
.editor-section {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-top: 30px;
}

.editor-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
}

/* textarea */
.editor-grid textarea {
    width: 100%;
    height: 200px;
    padding: 15px;

    border-radius: 12px;
    border: 1px solid var(--border);

    background: rgba(255,255,255,0.05);
    color: white;

    font-family: monospace;
    font-size: 14px;
}

/* preview bigger */
#preview-frame {
    width: 100%;
    height: 350px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: white;
}

/* NAVIGATION */
nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
}

.nav-left h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 30px;
}

.nav-right a {
    color: #e2e8f0;
    text-decoration: none;
    font-weight: 500;
    transition: 0.3s;
}

.nav-right a:hover,
.nav-right a.active {
    color: var(--primary);
}

.nav-right button {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
}

.nav-right button:hover {
    transform: scale(1.05);
    box-shadow: 0 5px 15px rgba(99,102,241,0.4);
}


#pricing-hero {
    padding: 60px 0 28px;
    text-align: center;
}

#pricing-hero h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 10px;
    background: linear-gradient(135deg, #60a5fa, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

#pricing-hero p {
    font-size: 1.2rem;
    color: #94a3b8;
    max-width: 520px;
    margin: 0 auto;
}

#external-partners {
    padding: 60px 0;
    background: rgba(255,255,255,0.02);
}

.partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 30px;
}

.partner-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    transition: 0.3s;
}

.partner-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary);
    box-shadow: 0 20px 40px rgba(99,102,241,0.2);
}

.partner-card h4 {
    font-size: 1.5rem;
    margin-bottom: 10px;
}

.partner-card p {
    color: #94a3b8;
    margin-bottom: 20px;
}

.partner-link {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
}

.partner-link:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(99,102,241,0.4);
}

/* MODALS */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    backdrop-filter: blur(5px);
}

.modal-content {
    background: linear-gradient(135deg, #1e293b, #0f172a);
    border-radius: 16px;
    padding: 30px;
    max-width: 500px;
    width: 90%;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 25px 50px rgba(0,0,0,0.5);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.modal-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
}

.modal-close {
    background: none;
    border: none;
    color: #94a3b8;
    font-size: 24px;
    cursor: pointer;
    padding: 5px;
    border-radius: 50%;
    transition: 0.3s;
}

.modal-close:hover {
    background: rgba(255,255,255,0.1);
    color: white;
}

.modal-body {
    color: #e2e8f0;
}

.token-calculation {
    background: rgba(255,255,255,0.05);
    padding: 15px;
    border-radius: 8px;
    margin: 15px 0;
}

.token-calculation p {
    margin: 5px 0;
    font-size: 14px;
}

.token-shortfall {
    color: #ef4444;
    font-weight: 600;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
    width: 100%;
}

.btn-primary:hover:not(:disabled) {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(99,102,241,0.4);
}

.btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-secondary {
    background: rgba(255,255,255,0.1);
    color: #e2e8f0;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
    width: 100%;
}

.btn-secondary:hover {
    background: rgba(255,255,255,0.2);
}

.modal-actions {
    display: flex;
    gap: 15px;
    margin-top: 20px;
}

.coupon-success {
    text-align: center;
}

.coupon-code {
    background: rgba(255,255,255,0.1);
    border: 2px dashed var(--primary);
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
}

.coupon-code code {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary);
    background: rgba(99,102,241,0.1);
    padding: 5px 10px;
    border-radius: 4px;
    flex: 1;
}

#copy-coupon {
    background: var(--primary);
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: 0.3s;
}

#copy-coupon:hover {
    background: var(--secondary);
}

.coupon-actions {
    display: flex;
    gap: 15px;
    margin-top: 20px;
}

/* TOKEN PURCHASE SPECIFIC */
.token-slider-row {
    display: flex;
    align-items: center;
    gap: 15px;
    margin: 15px 0;
}

#purchase-token-slider {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: rgba(255,255,255,0.2);
    outline: none;
    -webkit-appearance: none;
}

#purchase-token-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary);
    cursor: pointer;
    box-shadow: 0 0 10px rgba(99,102,241,0.5);
}

#purchase-max-tokens {
    background: rgba(255,255,255,0.1);
    color: #e2e8f0;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: 0.3s;
}

#purchase-max-tokens:hover {
    background: rgba(255,255,255,0.2);
}

/* ================= SPACING IMPROVEMENT ================= */
.analysis-card h3 {
    margin-bottom: 10px;
}

.analysis-card ul {
    margin-top: 12px;
    padding-left: 20px;
}

.analysis-card li {
    margin-bottom: 8px;
}

/* ================= FIX ALIGNMENT ================= */
.results-section,
.analysis-grid,
.chart-section,
.score-grid {
    margin-top: 20px;
    float: none !important;
}

/* ===== EDITOR SPLIT UI ===== */

.editor-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.editor-panel {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.editor-panel textarea {
    height: 280px;
    padding: 12px;

    border-radius: 12px;
    border: 1px solid var(--border);

    background: #020617;
    color: #38bdf8;

    font-family: monospace;
}

/* SCROLL REPORT BOX */
.reports-box {
    max-height: 300px;
    overflow-y: auto;
    padding-right: 10px;
}

/* BUTTON STYLE */
.result-actions button,
#apply-editor {
    padding: 10px 18px;
    border-radius: 999px;

    background: linear-gradient(135deg,var(--primary),var(--secondary));
    color: white;

    border: none;
    cursor: pointer;
}

/* PREVIEW */
#preview-frame {
    width: 100%;
    height: 400px;
    margin-top: 15px;

    border-radius: 12px;
    background: white;
}

/* ERROR MESSAGE STYLING */
.error-message {
    display: none;
    width: 100%;
    padding: 12px 16px;
    margin-top: 12px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    background-color: rgba(255, 107, 107, 0.1);
    color: #ff6b6b;
    border: 1px solid rgba(255, 107, 107, 0.3);
    animation: slideIn 0.3s ease;
}

.error-message.success {
    background-color: rgba(81, 207, 102, 0.1);
    color: #51cf66;
    border: 1px solid rgba(81, 207, 102, 0.3);
}

.shop-section {
    width: 100%;
    padding: 30px;
    border-radius: 24px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
}

.shop-section h2 {
    font-size: 24px;
    margin-bottom: 10px;
}

.shop-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 20px;
    color: var(--text-secondary);
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
}

.product-card {
    padding: 22px;
    border-radius: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.product-card h4 {
    margin: 0;
    font-size: 18px;
}

.product-card p {
    color: var(--text-secondary);
    line-height: 1.5;
}

.product-card span {
    display: block;
    margin-top: 6px;
    font-size: 14px;
    color: var(--text-secondary);
}

.buy-button {
    margin-top: auto;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    background: linear-gradient(180deg, #d1d5db 0%, #6b7280 100%);
    color: #ffffff;
    cursor: pointer;
    font-weight: 600;
    transition: 0.2s ease;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 2px 4px rgba(0,0,0,0.5);
}

.buy-button:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
}

.purchase-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.purchase-modal.is-open {
    display: flex;
}

.purchase-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.72);
    backdrop-filter: blur(12px);
}

.purchase-dialog {
    position: relative;
    width: min(460px, 100%);
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    padding: 28px;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 0.98));
    border: 1px solid rgba(148, 163, 184, 0.28);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
    color: var(--text-main);
}

.purchase-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(148, 163, 184, 0.26);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-main);
    cursor: pointer;
    font-size: 22px;
    line-height: 1;
}

.purchase-kicker {
    width: fit-content;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.16);
    color: #a5b4fc;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
}

.purchase-dialog h3 {
    margin: 14px 40px 8px 0;
    font-size: 24px;
}

.purchase-description {
    margin: 0 0 18px;
    color: var(--text-secondary);
    line-height: 1.5;
}

.purchase-summary,
.purchase-total {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px 16px;
    padding: 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(148, 163, 184, 0.18);
}

.purchase-summary span,
.purchase-total span {
    color: var(--text-secondary);
    font-size: 14px;
}

.purchase-field {
    display: grid;
    gap: 8px;
    margin-top: 16px;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 600;
}

.purchase-field input {
    width: 100%;
    padding: 13px 14px;
    border-radius: 14px;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: rgba(15, 23, 42, 0.8);
    color: var(--text-main);
    outline: none;
}

.purchase-field input:focus {
    border-color: rgba(99, 102, 241, 0.78);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.18);
}

.token-slider-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
    margin: 14px 0 18px;
}

.token-slider-row input {
    accent-color: var(--primary);
}

.token-slider-row button,
.purchase-secondary,
.purchase-primary {
    border: none;
    cursor: pointer;
    font-weight: 700;
}

.token-slider-row button {
    padding: 10px 14px;
    border-radius: 12px;
    background: rgba(99, 102, 241, 0.16);
    color: #c7d2fe;
}

.purchase-message {
    display: none;
    margin-top: 16px;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid rgba(248, 113, 113, 0.32);
    background: rgba(127, 29, 29, 0.18);
    color: #fecaca;
    font-size: 14px;
}

.purchase-message.is-visible {
    display: block;
}

.purchase-message.success {
    border-color: rgba(74, 222, 128, 0.34);
    background: rgba(20, 83, 45, 0.2);
    color: #bbf7d0;
}

.purchase-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 20px;
}

.purchase-secondary,
.purchase-primary {
    min-height: 44px;
    padding: 0 18px;
    border-radius: 14px;
}

.purchase-secondary {
    background: rgba(255, 255, 255, 0.07);
    color: var(--text-main);
}

.purchase-primary {
    background: linear-gradient(135deg,var(--secondary),var(--primary));
    color: white;
    box-shadow: 0 14px 28px rgba(99,102,241,0.24);
}

.purchase-primary:disabled {
    cursor: not-allowed;
    opacity: 0.65;
    box-shadow: none;
}

.plan-payment-message {
    position: fixed;
    left: 50%;
    bottom: 28px;
    z-index: 2200;
    display: none;
    max-width: min(520px, calc(100vw - 32px));
    padding: 14px 18px;
    border-radius: 14px;
    background: rgba(127, 29, 29, 0.94);
    border: 1px solid rgba(248, 113, 113, 0.4);
    color: #fee2e2;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.38);
    transform: translateX(-50%);
    font-weight: 600;
}

.plan-payment-message.is-visible {
    display: block;
}

.plan-payment-message.success {
    background: rgba(20, 83, 45, 0.94);
    border-color: rgba(74, 222, 128, 0.4);
    color: #dcfce7;
}

@media (max-width: 560px) {
    .purchase-dialog {
        padding: 22px;
        border-radius: 18px;
    }

    .purchase-actions {
        flex-direction: column-reverse;
    }

    .purchase-secondary,
    .purchase-primary {
        width: 100%;
    }
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
