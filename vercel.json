{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/auth", "destination": "/frontend/pages/auth.html" },
    { "source": "/dashboard", "destination": "/frontend/pages/dashboard.html" },
    { "source": "/plans", "destination": "/frontend/pages/plans.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
