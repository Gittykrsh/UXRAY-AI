{
  "services": [
    {
      "name": "uxrayai-backend",
      "env": "node",
      "plan": "free",
      "buildCommand": "npm install",
      "startCommand": "node server.js",
      "envVars": [
        {
          "key": "MONGODB_URI",
          "value": "@mongodb_uri"
        },
        {
          "key": "JWT_SECRET",
          "value": "@jwt_secret"
        },
        {
          "key": "GOOGLE_API_KEY",
          "value": "@google_api_key"
        },
        {
          "key": "STRIPE_SECRET_KEY",
          "value": "@stripe_secret_key"
        }
      ]
    }
  ]
}
